package main

import (
	"bytes"
	"encoding/json"
	"net/http"
	"os"
)

type invokeRequest struct {
	Input      map[string]any `json:"input"`
	Checkpoint *State         `json:"checkpoint"`
}

func main() {
	http.HandleFunc("/invoke", invoke)
	http.HandleFunc("/health", func(w http.ResponseWriter, r *http.Request) {
		_ = json.NewEncoder(w).Encode(map[string]string{"status": "ok", "agent": "{{ .AgentName }}"})
	})
	_ = http.ListenAndServe(":8000", nil)
}

func invoke(w http.ResponseWriter, r *http.Request) {
	var req invokeRequest
	_ = json.NewDecoder(r.Body).Decode(&req)
	state := req.Checkpoint
	if state == nil {
		state = &State{}
	}
	state.Turns++
	answer := callRuntimeLLM(req.Input)
	state.LastAnswer = answer
	_ = json.NewEncoder(w).Encode(map[string]any{
		"output": map[string]any{"answer": answer},
		"checkpoint": state,
	})
}

func callRuntimeLLM(input map[string]any) string {
	endpoint := os.Getenv("LITELLM_PROXY_URL")
	if endpoint == "" {
		endpoint = "http://localhost:4000"
	}
	body, _ := json.Marshal(map[string]any{
		"model": os.Getenv("RUNTIME_MODEL"),
		"messages": []map[string]string{{"role": "user", "content": "Handle agent input"}},
	})
	resp, err := http.Post(endpoint+"/v1/chat/completions", "application/json", bytes.NewReader(body))
	if err != nil {
		return "runtime LLM unavailable"
	}
	defer resp.Body.Close()
	return "ok"
}
