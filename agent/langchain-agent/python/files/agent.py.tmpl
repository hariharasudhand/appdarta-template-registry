# {{ .AgentName }} - LangChain agent (AppDarta managed)
# All LLM calls go through LiteLLM proxy (DHIL-RT enforces runtime policy).

import os
from fastapi import FastAPI
from langchain.agents import AgentExecutor, create_tool_calling_agent
from langchain.prompts import ChatPromptTemplate
from langchain_openai import ChatOpenAI
from langchain_core.tools import tool

app = FastAPI()

LITELLM_ENDPOINT = os.environ.get("LITELLM_PROXY_URL", "http://localhost:4000")
LITELLM_MODEL = os.environ.get("RUNTIME_MODEL", "gpt-4o")

llm = ChatOpenAI(
    base_url=f"{LITELLM_ENDPOINT}/v1",
    api_key=os.environ.get("RUNTIME_L2_API_KEY", "not-set"),
    model=LITELLM_MODEL,
)

prompt = ChatPromptTemplate.from_messages([
    ("system", "You are a helpful assistant for {{ .AgentName }}."),
    ("human", "{input}"),
    ("placeholder", "{agent_scratchpad}"),
])

@tool
def example_tool(query: str) -> str:
    """Example tool - replace with real tool implementations."""
    return f"Tool result for: {query}"

tools = [example_tool]
agent = create_tool_calling_agent(llm, tools, prompt)
executor = AgentExecutor(agent=agent, tools=tools, verbose=False)

@app.post("/invoke")
async def invoke(body: dict):
    result = executor.invoke({"input": body.get("input", "")})
    return {"output": {"result": result.get("output", "")}}

@app.get("/health")
def health():
    return {"status": "ok", "agent": "{{ .AgentName }}"}
