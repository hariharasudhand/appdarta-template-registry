import os
import httpx
from fastapi import FastAPI

app = FastAPI()
SUB_AGENTS = [s for s in os.environ.get("SUB_AGENT_URLS", "").split(",") if s]

@app.post("/invoke")
async def invoke(body: dict):
    payload = body.get("input", {})
    results = []
    async with httpx.AsyncClient(timeout=30) as client:
        for idx, url in enumerate(SUB_AGENTS):
            resp = await client.post(url.rstrip("/") + "/invoke", json={"input": {**payload, "agent_index": idx}})
            results.append(resp.json().get("output", {}))
    return {"output": {"agent_results": results}}

@app.get("/health")
def health():
    return {"status": "ok", "agent": "{{ .AgentName }}"}
