# Cloud Run service fragment for {{ .AgentName }}
apiVersion: serving.knative.dev/v1
kind: Service
metadata:
  name: {{ .AgentName }}
spec:
  template:
    spec:
      containers:
        - image: gcr.io/PROJECT/{{ .AgentName }}:latest
          ports:
            - containerPort: 8080
          env:
            - name: PORT
              value: "8080"
