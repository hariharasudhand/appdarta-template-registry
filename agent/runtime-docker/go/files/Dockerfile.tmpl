FROM golang:1.23 AS build
WORKDIR /src
COPY . .
RUN test -f go.mod && go build -o /out/{{ snake .AgentName }} ./agents/{{ .AgentName }} || (echo "expected Go agent source under agents/{{ .AgentName }}" && exit 1)

FROM gcr.io/distroless/base-debian12
WORKDIR /app
COPY --from=build /out/{{ snake .AgentName }} /app/{{ snake .AgentName }}
EXPOSE 8080
ENTRYPOINT ["/app/{{ snake .AgentName }}"]
