#!/usr/bin/env bash
set -euo pipefail

# Manual G10 proof for the kafka-local scaffold:
#   1. Start Redpanda from this compose file.
#   2. Produce one JSON event.
#   3. Consume one JSON event through the same rpk sidecar contract used by
#      event-stream-consumer-go.
#   4. POST the consumed payload into context-service tank ingest.

TOPIC="${KAFKA_PROOF_TOPIC:-appdarta.proof.events}"
TANK_NAME="${TANK_NAME:-event-proof-tank}"
PARTITION="${TANK_PARTITION:-events}"
CONTEXT_SERVICE_URL="${APPDARTA_CONTEXT_SERVICE_URL:-http://127.0.0.1:18001}"

docker compose up -d redpanda

until docker compose exec -T redpanda rpk cluster info >/dev/null 2>&1; do
  sleep 1
done

docker compose exec -T redpanda rpk topic create "$TOPIC" >/dev/null 2>&1 || true

EVENT='{"id":"proof-1","source":"kafka-local","status":"created"}'
printf '%s\n' "$EVENT" | docker compose exec -T redpanda rpk topic produce "$TOPIC" >/dev/null

CONSUMED="$(docker compose exec -T redpanda rpk topic consume "$TOPIC" --num 1 --format json)"
CONTENT_B64="$(printf '%s' "$CONSUMED" | python3 -c 'import base64,sys; print(base64.b64encode(sys.stdin.buffer.read()).decode())')"

curl -fsS \
  -H 'Content-Type: application/json' \
  -d "{\"tank_name\":\"${TANK_NAME}\",\"partition\":\"${PARTITION}\",\"filename\":\"${TOPIC}.json\",\"client_id\":\"kafka-local-proof\",\"content_b64\":\"${CONTENT_B64}\"}" \
  "${CONTEXT_SERVICE_URL%/}/tank/ingest/document" >/dev/null

echo "kafka-local proof ok: ${TOPIC} -> ${TANK_NAME}/${PARTITION}"
