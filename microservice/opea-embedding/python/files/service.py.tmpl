import os
import httpx
from fastapi import FastAPI, HTTPException
from pydantic import BaseModel
from typing import Union

app = FastAPI(title="{{ .ServiceName }}", version="1.0.0")

BACKEND_URL  = os.getenv("EMBEDDING_BACKEND_URL", "http://localhost:8090")
MODEL_ID     = os.getenv("EMBEDDING_MODEL_ID", "BAAI/bge-base-en-v1.5")
PORT         = int(os.getenv("PORT", "6000"))


class EmbeddingRequest(BaseModel):
    model: str = MODEL_ID
    input: Union[str, list[str]]


class EmbeddingData(BaseModel):
    object: str = "embedding"
    embedding: list[float]
    index: int


class EmbeddingResponse(BaseModel):
    object: str = "list"
    data: list[EmbeddingData]
    model: str


@app.post("/v1/embeddings", response_model=EmbeddingResponse)
async def create_embeddings(req: EmbeddingRequest):
    texts = [req.input] if isinstance(req.input, str) else req.input
    async with httpx.AsyncClient(timeout=30) as client:
        resp = await client.post(f"{BACKEND_URL}/embed", json={"inputs": texts})
        if resp.status_code != 200:
            raise HTTPException(status_code=resp.status_code, detail=resp.text)
        vectors = resp.json()
    return EmbeddingResponse(
        data=[EmbeddingData(embedding=v, index=i) for i, v in enumerate(vectors)],
        model=req.model,
    )


@app.get("/v1/health_check")
async def health_check():
    return {"status": "healthy"}


if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=PORT)
