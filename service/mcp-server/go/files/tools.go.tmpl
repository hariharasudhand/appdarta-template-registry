package main

import "fmt"

func ListTools() []map[string]any {
	return []map[string]any{
		{
			"name":        "echo",
			"description": "Echo back the provided message. Replace with your tool.",
			"inputSchema": map[string]any{
				"type": "object",
				"properties": map[string]any{
					"message": map[string]any{"type": "string", "description": "Message to echo"},
				},
				"required": []string{"message"},
			},
		},
	}
}

func CallTool(name string, args map[string]any) map[string]any {
	switch name {
	case "echo":
		msg, _ := args["message"].(string)
		return map[string]any{
			"content": []map[string]any{{"type": "text", "text": msg}},
		}
	default:
		return map[string]any{
			"isError": true,
			"content": []map[string]any{{"type": "text", "text": fmt.Sprintf("Unknown tool: %s", name)}},
		}
	}
}
