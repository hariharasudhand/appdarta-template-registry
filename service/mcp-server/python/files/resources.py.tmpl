"""Resource handlers for {{ .ServiceName }}."""


def list_resources() -> list[dict]:
    return [
        {
            "uri": "{{ .ServiceName }}://info",
            "name": "Service Info",
            "description": "Basic information about this MCP server.",
            "mimeType": "text/plain",
        },
    ]


async def read_resource(uri: str) -> list[dict]:
    if uri == "{{ .ServiceName }}://info":
        return [
            {
                "uri": uri,
                "mimeType": "text/plain",
                "text": "{{ .ServiceName }} MCP server v1.0.0",
            }
        ]

    return [{"uri": uri, "mimeType": "text/plain", "text": f"Resource not found: {uri}"}]
