"""{{ .ServiceName }} — MCP server (Model Context Protocol)."""
import asyncio
import json
import sys
from typing import Any

from tools import list_tools, call_tool
from resources import list_resources, read_resource

SERVER_INFO = {
    "name": "{{ .ServiceName }}",
    "version": "1.0.0",
}

CAPABILITIES = {
    "tools": {"listChanged": False},
    "resources": {"listChanged": False},
    "prompts": {},
}


async def handle_request(req: dict) -> dict:
    method = req.get("method", "")
    rid = req.get("id")

    if method == "initialize":
        return {
            "jsonrpc": "2.0", "id": rid,
            "result": {
                "protocolVersion": "2025-11-25",
                "serverInfo": SERVER_INFO,
                "capabilities": CAPABILITIES,
            },
        }

    if method == "initialized":
        return None  # notification, no response

    if method == "tools/list":
        return {"jsonrpc": "2.0", "id": rid, "result": {"tools": list_tools()}}

    if method == "tools/call":
        params = req.get("params", {})
        result = await call_tool(params.get("name", ""), params.get("arguments", {}))
        return {"jsonrpc": "2.0", "id": rid, "result": result}

    if method == "resources/list":
        return {"jsonrpc": "2.0", "id": rid, "result": {"resources": list_resources()}}

    if method == "resources/read":
        uri = req.get("params", {}).get("uri", "")
        content = await read_resource(uri)
        return {"jsonrpc": "2.0", "id": rid, "result": {"contents": content}}

    return {
        "jsonrpc": "2.0", "id": rid,
        "error": {"code": -32601, "message": f"Method not found: {method}"},
    }


async def stdio_loop() -> None:
    reader = asyncio.StreamReader()
    protocol = asyncio.StreamReaderProtocol(reader)
    loop = asyncio.get_event_loop()
    await loop.connect_read_pipe(lambda: protocol, sys.stdin.buffer)
    writer_transport, writer_protocol = await loop.connect_write_pipe(
        lambda: asyncio.BaseProtocol(), sys.stdout.buffer
    )
    writer = asyncio.StreamWriter(writer_transport, writer_protocol, None, loop)

    while True:
        header = await reader.readline()
        if not header:
            break
        line = await reader.readline()  # blank line after Content-Length header
        length = int(header.decode().split(":")[1].strip())
        body = await reader.readexactly(length)
        req = json.loads(body)

        resp = await handle_request(req)
        if resp is not None:
            payload = json.dumps(resp).encode()
            writer.write(f"Content-Length: {len(payload)}\r\n\r\n".encode() + payload)
            await writer.drain()


if __name__ == "__main__":
    asyncio.run(stdio_loop())
