"""{{ .ServiceName }} — Supervisor orchestrator."""
from __future__ import annotations
import os
from typing import Any
from worker import ResearchWorker, SummaryWorker, BaseWorker

WORKERS: dict[str, BaseWorker] = {
    "research": ResearchWorker(),
    "summary": SummaryWorker(),
}


class Orchestrator:
    """Routes tasks to workers and aggregates results."""

    async def run(self, task: str, context: dict[str, Any] | None = None) -> dict[str, Any]:
        plan = await self._plan(task, context or {})
        results = {}
        for step in plan:
            worker = WORKERS.get(step["role"])
            if worker is None:
                results[step["role"]] = {"error": f"No worker for role: {step['role']}"}
                continue
            results[step["role"]] = await worker.execute(step["input"], context=results)
        return await self._aggregate(task, results)

    async def _plan(self, task: str, context: dict[str, Any]) -> list[dict]:
        """Decompose task into steps. Replace with LLM planning call."""
        return [
            {"role": "research", "input": task},
            {"role": "summary", "input": task},
        ]

    async def _aggregate(self, task: str, results: dict[str, Any]) -> dict[str, Any]:
        """Merge worker outputs. Replace with LLM synthesis call."""
        return {"task": task, "result": results, "status": "completed"}


# FastAPI entrypoint
if __name__ == "__main__":
    import asyncio
    import json
    from fastapi import FastAPI
    from pydantic import BaseModel
    import uvicorn

    app = FastAPI(title="{{ .ServiceName }}", version="1.0.0")
    orchestrator = Orchestrator()

    class RunRequest(BaseModel):
        task: str
        context: dict[str, Any] | None = None

    @app.post("/v1/run")
    async def run(req: RunRequest):
        return await orchestrator.run(req.task, req.context)

    @app.get("/v1/health_check")
    async def health_check():
        return {"status": "healthy"}

    port = int(os.getenv("PORT", "9003"))
    uvicorn.run(app, host="0.0.0.0", port=port)
