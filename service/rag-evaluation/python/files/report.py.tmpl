"""Evaluation report generator for {{ .ServiceName }}."""
from __future__ import annotations
import json
from dataclasses import dataclass
from typing import Any

from evaluator import EvalResult


@dataclass
class EvalReport:
    run_id: str
    sample_count: int
    avg_faithfulness: float
    avg_context_precision: float
    avg_answer_relevancy: float
    samples: list[dict[str, Any]]

    def to_dict(self) -> dict[str, Any]:
        return {
            "run_id": self.run_id,
            "sample_count": self.sample_count,
            "averages": {
                "faithfulness": round(self.avg_faithfulness, 4),
                "context_precision": round(self.avg_context_precision, 4),
                "answer_relevancy": round(self.avg_answer_relevancy, 4),
            },
            "samples": self.samples,
        }

    def to_json(self, indent: int = 2) -> str:
        return json.dumps(self.to_dict(), indent=indent)


def build_report(run_id: str, results: list[EvalResult]) -> EvalReport:
    if not results:
        return EvalReport(run_id=run_id, sample_count=0,
                          avg_faithfulness=0.0, avg_context_precision=0.0,
                          avg_answer_relevancy=0.0, samples=[])

    n = len(results)
    return EvalReport(
        run_id=run_id,
        sample_count=n,
        avg_faithfulness=sum(r.faithfulness for r in results) / n,
        avg_context_precision=sum(r.context_precision for r in results) / n,
        avg_answer_relevancy=sum(r.answer_relevancy for r in results) / n,
        samples=[r.to_dict() for r in results],
    )
