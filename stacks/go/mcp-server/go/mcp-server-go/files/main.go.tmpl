package main

import (
	"bufio"
	"encoding/json"
	"fmt"
	"log"
	"os"
	"strconv"
	"strings"
)

const protocolVersion = "2025-11-25"

var serverInfo = map[string]string{
	"name":    "{{ .ServiceName }}",
	"version": "1.0.0",
}

var capabilities = map[string]any{
	"tools":     map[string]any{"listChanged": false},
	"resources": map[string]any{"listChanged": false},
}

type rpcRequest struct {
	JSONRPC string          `json:"jsonrpc"`
	ID      any             `json:"id,omitempty"`
	Method  string          `json:"method"`
	Params  json.RawMessage `json:"params,omitempty"`
}

type rpcResponse struct {
	JSONRPC string `json:"jsonrpc"`
	ID      any    `json:"id,omitempty"`
	Result  any    `json:"result,omitempty"`
	Error   any    `json:"error,omitempty"`
}

func main() {
	reader := bufio.NewReader(os.Stdin)
	for {
		// Read Content-Length header
		header, err := reader.ReadString('\n')
		if err != nil {
			break
		}
		header = strings.TrimSpace(header)
		if !strings.HasPrefix(header, "Content-Length:") {
			continue
		}
		length, _ := strconv.Atoi(strings.TrimSpace(strings.TrimPrefix(header, "Content-Length:")))

		reader.ReadString('\n') // blank line

		body := make([]byte, length)
		if _, err := reader.Read(body); err != nil {
			log.Printf("read error: %v", err)
			break
		}

		var req rpcRequest
		if err := json.Unmarshal(body, &req); err != nil {
			continue
		}

		resp := handleRequest(req)
		if resp == nil {
			continue
		}

		payload, _ := json.Marshal(resp)
		fmt.Fprintf(os.Stdout, "Content-Length: %d\r\n\r\n%s", len(payload), payload)
	}
}

func handleRequest(req rpcRequest) *rpcResponse {
	switch req.Method {
	case "initialize":
		return &rpcResponse{
			JSONRPC: "2.0", ID: req.ID,
			Result: map[string]any{
				"protocolVersion": protocolVersion,
				"serverInfo":      serverInfo,
				"capabilities":    capabilities,
			},
		}
	case "initialized":
		return nil
	case "tools/list":
		return &rpcResponse{JSONRPC: "2.0", ID: req.ID, Result: map[string]any{"tools": ListTools()}}
	case "tools/call":
		var params struct {
			Name      string         `json:"name"`
			Arguments map[string]any `json:"arguments"`
		}
		json.Unmarshal(req.Params, &params)
		result := CallTool(params.Name, params.Arguments)
		return &rpcResponse{JSONRPC: "2.0", ID: req.ID, Result: result}
	case "resources/list":
		return &rpcResponse{JSONRPC: "2.0", ID: req.ID, Result: map[string]any{"resources": ListResources()}}
	case "resources/read":
		var params struct {
			URI string `json:"uri"`
		}
		json.Unmarshal(req.Params, &params)
		content := ReadResource(params.URI)
		return &rpcResponse{JSONRPC: "2.0", ID: req.ID, Result: map[string]any{"contents": content}}
	default:
		return &rpcResponse{
			JSONRPC: "2.0", ID: req.ID,
			Error: map[string]any{"code": -32601, "message": "Method not found: " + req.Method},
		}
	}
}
