package main

import "fmt"

func ListResources() []map[string]any {
	return []map[string]any{
		{
			"uri":         "{{ .ServiceName }}://info",
			"name":        "Service Info",
			"description": "Basic information about this MCP server.",
			"mimeType":    "text/plain",
		},
	}
}

func ReadResource(uri string) []map[string]any {
	switch uri {
	case "{{ .ServiceName }}://info":
		return []map[string]any{
			{"uri": uri, "mimeType": "text/plain", "text": "{{ .ServiceName }} MCP server v1.0.0"},
		}
	default:
		return []map[string]any{
			{"uri": uri, "mimeType": "text/plain", "text": fmt.Sprintf("Resource not found: %s", uri)},
		}
	}
}
