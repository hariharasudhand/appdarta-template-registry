package {{ snake .AgentName }}

import (
	"context"
	"testing"
)

func TestExecuteEmbedsInputWithAuditID(t *testing.T) {
	service := Service{
		Model: DeterministicModelClient{Dimensions: 4},
		Audit: NoopAuditor{},
	}
	resp, err := service.Execute(context.Background(), Request{
		Text: "patient note with pneumonia",
		ModelRef: "models/icd10.onnx",
		TraceID: "trace-test",
	})
	if err != nil {
		t.Fatalf("Execute: %v", err)
	}
	if len(resp.Embeddings) != 1 {
		t.Fatalf("embedding count = %d, want 1", len(resp.Embeddings))
	}
	if resp.Dimensions != 4 {
		t.Fatalf("dimensions = %d, want 4", resp.Dimensions)
	}
	if resp.AuditID == "" {
		t.Fatal("AuditID is empty")
	}
}
