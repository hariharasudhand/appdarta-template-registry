package main

import (
	"context"
	"fmt"
	"os"
	"strconv"
	"unsafe"

	"github.com/redis/go-redis/v9"
)

var rdb *redis.Client

func init() {
	rdb = redis.NewClient(&redis.Options{
		Addr:     os.Getenv("REDIS_URL"),
		Password: os.Getenv("REDIS_PASSWORD"),
	})
}

func searchRedis(ctx context.Context, embedding []float32, topK int) ([]Document, error) {
	indexName := os.Getenv("REDIS_INDEX_NAME")
	if indexName == "" {
		indexName = "{{ .ServiceName }}-index"
	}

	// Build KNN vector query for RediSearch VSS
	vecBytes := float32SliceToBytes(embedding)
	query := fmt.Sprintf("*=>[KNN %d @embedding $vec AS score]", topK)

	res, err := rdb.Do(ctx, "FT.SEARCH", indexName, query,
		"PARAMS", "2", "vec", vecBytes,
		"SORTBY", "score",
		"RETURN", "3", "text", "score", "metadata",
		"DIALECT", "2",
	).Result()
	if err != nil {
		return nil, fmt.Errorf("redis search: %w", err)
	}

	return parseSearchResults(res), nil
}

func parseSearchResults(raw interface{}) []Document {
	results, ok := raw.([]interface{})
	if !ok || len(results) < 1 {
		return nil
	}

	count, _ := strconv.Atoi(fmt.Sprintf("%v", results[0]))
	docs := make([]Document, 0, count)

	for i := 1; i+1 < len(results); i += 2 {
		id := fmt.Sprintf("%v", results[i])
		fields, ok := results[i+1].([]interface{})
		if !ok {
			continue
		}

		doc := Document{ID: id}
		for j := 0; j+1 < len(fields); j += 2 {
			key := fmt.Sprintf("%v", fields[j])
			val := fmt.Sprintf("%v", fields[j+1])
			switch key {
			case "text":
				doc.Text = val
			case "score":
				if f, err := strconv.ParseFloat(val, 32); err == nil {
					doc.Score = float32(f)
				}
			}
		}
		docs = append(docs, doc)
	}
	return docs
}

func float32SliceToBytes(vec []float32) []byte {
	b := make([]byte, len(vec)*4)
	for i, f := range vec {
		bits := *(*uint32)(unsafe.Pointer(&f))
		b[i*4] = byte(bits)
		b[i*4+1] = byte(bits >> 8)
		b[i*4+2] = byte(bits >> 16)
		b[i*4+3] = byte(bits >> 24)
	}
	return b
}
