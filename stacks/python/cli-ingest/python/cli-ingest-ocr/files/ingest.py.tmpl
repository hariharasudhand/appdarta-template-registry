"""{{ .TankName }} — CLI file ingestor with optional OCR.

Usage:
    python ingest.py --source <dir-or-file> [--ocr]

TankConnectorConfig fields consumed:
  content-field: text chunk embedding input
  field-mappings: source metadata field remapping
  response-path: not applicable (file-based; chunking replaces pagination)
"""
from __future__ import annotations

import argparse
import hashlib
import pathlib
import sys

from ocr import extract_text_ocr


def extract_text_direct(path: pathlib.Path) -> str:
    """Extract text from PDF/text file without OCR."""
    suffix = path.suffix.lower()
    if suffix == ".pdf":
        try:
            import pypdf
            reader = pypdf.PdfReader(str(path))
            return "\n".join(page.extract_text() or "" for page in reader.pages)
        except ImportError:
            sys.exit("pypdf not installed — run: pip install pypdf")
    return path.read_text(errors="replace")


def chunk(text: str, size: int = 512, overlap: int = 64) -> list[str]:
    """Split text into overlapping chunks for embedding."""
    words = text.split()
    chunks = []
    i = 0
    while i < len(words):
        chunks.append(" ".join(words[i : i + size]))
        i += size - overlap
    return chunks


def upsert(tank: str, record: dict) -> None:
    """Send one chunk to the context-service tank upsert endpoint."""
    # Wire to: POST http://context-service/tanks/{tank}/records
    import urllib.request, json
    data = json.dumps(record).encode()
    req = urllib.request.Request(
        f"http://localhost:8080/tanks/{tank}/records",
        data=data,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    with urllib.request.urlopen(req, timeout=10):
        pass


def ingest(source: str, use_ocr: bool) -> None:
    root = pathlib.Path(source)
    files = list(root.rglob("*")) if root.is_dir() else [root]
    tank = "{{ snake .TankName }}"

    for f in files:
        if not f.is_file():
            continue
        text = extract_text_ocr(f) if use_ocr else extract_text_direct(f)
        for i, c in enumerate(chunk(text)):
            upsert(tank, {
                "source": str(f),
                "page": i,
                "hash": hashlib.sha256(c.encode()).hexdigest()[:16],
                "content": c,   # content-field
            })


def main() -> None:
    parser = argparse.ArgumentParser(description="Ingest documents into {{ .TankName }}")
    parser.add_argument("--source", required=True)
    parser.add_argument("--ocr", action="store_true", help="Use OCR for scanned PDFs/images")
    args = parser.parse_args()
    ingest(args.source, args.ocr)


if __name__ == "__main__":
    main()
