import os
from fastapi import FastAPI
from crewai import Agent, Crew, Task
from langchain_openai import ChatOpenAI

app = FastAPI()

litellm_endpoint = os.environ.get("LITELLM_PROXY_URL", "http://localhost:4000")
llm = ChatOpenAI(
    base_url=f"{litellm_endpoint}/v1",
    api_key=os.environ.get("RUNTIME_L2_API_KEY", "not-set"),
    model=os.environ.get("RUNTIME_MODEL", "gpt-4o"),
)

researcher = Agent(role="Researcher", goal="Gather concise facts", backstory="Focused AppDarta research agent", llm=llm)
writer = Agent(role="Writer", goal="Write a clear answer", backstory="Turns research into useful output", llm=llm)

@app.post("/kickoff")
async def kickoff(body: dict):
    topic = body.get("inputs", {}).get("input", "")
    research = Task(description=f"Research: {topic}", expected_output="bullet facts", agent=researcher)
    write = Task(description="Write a final answer from the research.", expected_output="final answer", agent=writer)
    crew = Crew(agents=[researcher, writer], tasks=[research, write])
    result = crew.kickoff()
    return {"result": {"answer": str(result)}}

@app.get("/health")
def health():
    return {"status": "ok", "agent": "{{ .AgentName }}"}
