"""Tool handlers for {{ .ServiceName }}."""
from typing import Any


def list_tools() -> list[dict]:
    return [
        {
            "name": "echo",
            "description": "Echo back the provided message. Replace with your tool.",
            "inputSchema": {
                "type": "object",
                "properties": {
                    "message": {"type": "string", "description": "Message to echo"},
                },
                "required": ["message"],
            },
        },
    ]


async def call_tool(name: str, arguments: dict[str, Any]) -> dict:
    if name == "echo":
        return {
            "content": [{"type": "text", "text": arguments.get("message", "")}],
        }

    return {
        "isError": True,
        "content": [{"type": "text", "text": f"Unknown tool: {name}"}],
    }
