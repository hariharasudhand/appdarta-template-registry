apiVersion: appdarta.io/v1
kind: AgentPolicy
metadata:
  name: "{{ .AgentName }}"
  domain: "{{ .Domain }}"
spec:
  gateway_pipeline:
    in:
      - type: auth_enforcement
      - type: rate_limit
        config:
          requests_per_minute: 60
      - type: multi-agent-dispatch
        config:
          agents: []
          aggregation: merge
          timeout_seconds: 60
    out:
      - type: audit_logger
        async: true
