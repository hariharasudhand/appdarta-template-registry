"""RAGAS metrics runner for {{ .ServiceName }}."""
from __future__ import annotations
import os
from dataclasses import dataclass
from typing import Any

from tracer import get_tracer


@dataclass
class EvalSample:
    question: str
    answer: str
    contexts: list[str]
    ground_truth: str | None = None


@dataclass
class EvalResult:
    faithfulness: float
    context_precision: float
    answer_relevancy: float
    run_id: str

    def to_dict(self) -> dict[str, Any]:
        return {
            "run_id": self.run_id,
            "faithfulness": self.faithfulness,
            "context_precision": self.context_precision,
            "answer_relevancy": self.answer_relevancy,
        }


class Evaluator:
    """Runs RAGAS metrics on a batch of RAG samples."""

    def __init__(self) -> None:
        self._tracer = get_tracer()

    async def evaluate(self, samples: list[EvalSample], run_id: str) -> list[EvalResult]:
        results = []
        trace = self._tracer.start_trace(run_id)

        for i, s in enumerate(samples):
            faithfulness = await self._faithfulness(s)
            context_precision = await self._context_precision(s)
            answer_relevancy = await self._answer_relevancy(s)

            r = EvalResult(
                faithfulness=faithfulness,
                context_precision=context_precision,
                answer_relevancy=answer_relevancy,
                run_id=f"{run_id}-{i}",
            )
            results.append(r)
            trace.log(r.to_dict())

        trace.finish()
        return results

