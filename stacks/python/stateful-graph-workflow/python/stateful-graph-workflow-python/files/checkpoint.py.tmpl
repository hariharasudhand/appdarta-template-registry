"""Pluggable checkpoint adapter for {{ .ServiceName }}."""
from __future__ import annotations
from abc import ABC, abstractmethod
from typing import Any
import json


class CheckpointAdapter(ABC):
    """Swap implementation without changing workflow code."""

    @abstractmethod
    async def save(self, run_id: str, state: dict[str, Any]) -> None: ...

    @abstractmethod
    async def load(self, run_id: str) -> dict[str, Any] | None: ...

    @abstractmethod
    async def delete(self, run_id: str) -> None: ...


class InMemoryCheckpoint(CheckpointAdapter):
    """Development-only in-memory checkpoint. No persistence across restarts."""

    def __init__(self) -> None:
        self._store: dict[str, dict[str, Any]] = {}

    async def save(self, run_id: str, state: dict[str, Any]) -> None:
        self._store[run_id] = state

    async def load(self, run_id: str) -> dict[str, Any] | None:
        return self._store.get(run_id)

    async def delete(self, run_id: str) -> None:
        self._store.pop(run_id, None)


class RedisCheckpoint(CheckpointAdapter):
    """Production checkpoint backed by Redis. Survives restarts."""

    def __init__(self, redis_url: str, ttl_seconds: int = 3600) -> None:
        import redis.asyncio as aioredis
        self._redis = aioredis.from_url(redis_url)
        self._ttl = ttl_seconds

    async def save(self, run_id: str, state: dict[str, Any]) -> None:
        await self._redis.setex(f"wf:{run_id}", self._ttl, json.dumps(state))

    async def load(self, run_id: str) -> dict[str, Any] | None:
        raw = await self._redis.get(f"wf:{run_id}")
        return json.loads(raw) if raw else None

    async def delete(self, run_id: str) -> None:
        await self._redis.delete(f"wf:{run_id}")
