// ConsumerConfig mirrors TankConnectorConfig.consumer.
type ConsumerConfig struct {
	Enabled           bool     `yaml:"enabled"`
	Type              string   `yaml:"type"`
	Brokers           []string `yaml:"brokers"`
	Topics            []string `yaml:"topics"`
	Topic             string   `yaml:"topic"`
	GroupID           string   `yaml:"group-id"`
	Deserializer      string   `yaml:"deserializer"`
	SchemaRegistryURL string   `yaml:"schema-registry-url"`
	DLQTopic          string   `yaml:"dlq-topic"`
	MaxPollRecords    int      `yaml:"max-poll-records"`
}

type ConsumerRecord struct {
	Topic     string
	Partition int
	Offset    int64
	Key       []byte
	Value     []byte
	Timestamp time.Time
}

type EventPoller interface {
	Poll(ctx context.Context, topics []string, maxRecords int) ([]ConsumerRecord, error)
	Commit(ctx context.Context, record ConsumerRecord) error
	SendDLQ(ctx context.Context, dlqTopic string, record ConsumerRecord, cause error) error
	Close() error
}

type TankUpsertFunc func(ctx context.Context, topic string, record map[string]any) error

// NewContextServiceTankUpsert returns a hook that sends each consumed event into
// context-service using the same ingest contract as `darta tank ingest`.
func NewContextServiceTankUpsert(contextServiceURL, tankName, partition string) TankUpsertFunc {
	base := strings.TrimRight(strings.TrimSpace(contextServiceURL), "/")
	if base == "" {
		base = strings.TrimRight(os.Getenv("APPDARTA_CONTEXT_SERVICE_URL"), "/")
	}
	if base == "" {
		base = "http://127.0.0.1:18001"
	}
	if partition == "" {
		partition = "events"
	}
	return func(ctx context.Context, topic string, record map[string]any) error {
		raw, err := json.Marshal(record)
		if err != nil {
			return err
		}
		body := map[string]any{
			"tank_name":   tankName,
			"partition":   partition,
			"filename":    fmt.Sprintf("%s-event.json", strings.TrimSpace(topic)),
			"client_id":   "event-stream-consumer",
			"content_b64": base64.StdEncoding.EncodeToString(raw),
		}
		payload, err := json.Marshal(body)
		if err != nil {
			return err
		}
		req, err := http.NewRequestWithContext(ctx, http.MethodPost, base+"/tank/ingest/document", bytes.NewReader(payload))
		if err != nil {
			return err
		}
		req.Header.Set("Content-Type", "application/json")
		resp, err := http.DefaultClient.Do(req)
		if err != nil {
			return err
		}
		defer resp.Body.Close()
		if resp.StatusCode < 200 || resp.StatusCode >= 300 {
			return fmt.Errorf("context-service tank ingest returned HTTP %d", resp.StatusCode)
		}
		return nil
	}
}

// RedpandaRPKPoller is the no-library Kafka adapter used by the local Redpanda
// scaffold. It shells out to `rpk` so generated consumers do not need a Kafka
// client dependency; production teams can swap this for a native client behind
// the same EventPoller interface.
type RedpandaRPKPoller struct {
	Brokers []string
	GroupID string
	RPKPath string
}

func NewRedpandaRPKPoller(brokers []string, groupID string) *RedpandaRPKPoller {
	path := strings.TrimSpace(os.Getenv("RPK_BIN"))
	if path == "" {
		path = "rpk"
	}
	return &RedpandaRPKPoller{Brokers: brokers, GroupID: groupID, RPKPath: path}
}

func (p *RedpandaRPKPoller) Poll(ctx context.Context, topics []string, maxRecords int) ([]ConsumerRecord, error) {
	if maxRecords <= 0 {
		maxRecords = 100
	}
	if len(topics) == 0 {
		return nil, fmt.Errorf("no topics configured")
	}
	var out []ConsumerRecord
	perTopic := maxRecords / len(topics)
	if perTopic <= 0 {
		perTopic = 1
	}
	for _, topic := range topics {
		if len(out) >= maxRecords {
			break
		}
		records, err := p.consumeTopic(ctx, topic, perTopic)
		if err != nil {
			return out, err
		}
		out = append(out, records...)
	}
	if len(out) > maxRecords {
		out = out[:maxRecords]
	}
	return out, nil
}

func (p *RedpandaRPKPoller) consumeTopic(ctx context.Context, topic string, maxRecords int) ([]ConsumerRecord, error) {
	args := []string{"topic", "consume", topic, "--brokers", strings.Join(p.Brokers, ","), "--num", fmt.Sprint(maxRecords), "--format", "json"}
	if strings.TrimSpace(p.GroupID) != "" {
		args = append(args, "--group", p.GroupID)
	}
	cmd := exec.CommandContext(ctx, p.RPKPath, args...)
	raw, err := cmd.Output()
	if err != nil {
		if ctx.Err() != nil {
			return nil, nil
		}
		return nil, fmt.Errorf("rpk consume %s: %w", topic, err)
	}
	var records []ConsumerRecord
	for _, line := range bytes.Split(raw, []byte("\n")) {
		line = bytes.TrimSpace(line)
		if len(line) == 0 {
			continue
		}
		record, err := parseRPKRecord(topic, line)
		if err != nil {
			return nil, err
		}
		records = append(records, record)
	}
	return records, nil
}

func parseRPKRecord(defaultTopic string, raw []byte) (ConsumerRecord, error) {
	var r struct {
		Topic     string          `json:"topic"`
		Partition int             `json:"partition"`
		Offset    int64           `json:"offset"`
		Key       json.RawMessage `json:"key"`
		Value     json.RawMessage `json:"value"`
		Timestamp string          `json:"timestamp"`
	}
	if err := json.Unmarshal(raw, &r); err != nil {
		return ConsumerRecord{}, fmt.Errorf("parse rpk JSON record: %w", err)
	}
	value := bytes.TrimSpace(r.Value)
	if len(value) > 0 && value[0] == '"' {
		var s string
		if err := json.Unmarshal(value, &s); err == nil {
			value = []byte(s)
		}
	}
	key := bytes.TrimSpace(r.Key)
	if len(key) > 0 && key[0] == '"' {
		var s string
		if err := json.Unmarshal(key, &s); err == nil {
			key = []byte(s)
		}
	}
	ts, _ := time.Parse(time.RFC3339Nano, r.Timestamp)
	topic := strings.TrimSpace(r.Topic)
	if topic == "" {
		topic = defaultTopic
	}
	return ConsumerRecord{
		Topic:     topic,
		Partition: r.Partition,
		Offset:    r.Offset,
		Key:       key,
		Value:     value,
		Timestamp: ts,
	}, nil
}

func (p *RedpandaRPKPoller) Commit(ctx context.Context, record ConsumerRecord) error {
	// rpk commits when running as a group consumer. Native clients should commit
	// explicit offsets behind the EventPoller interface.
	return nil
}

func (p *RedpandaRPKPoller) SendDLQ(ctx context.Context, dlqTopic string, record ConsumerRecord, cause error) error {
	if strings.TrimSpace(dlqTopic) == "" {
		return nil
	}
	envelope, err := json.Marshal(map[string]any{
		"source_topic": record.Topic,
		"partition":    record.Partition,
		"offset":       record.Offset,
		"cause":        cause.Error(),
		"value_b64":    base64.StdEncoding.EncodeToString(record.Value),
	})
	if err != nil {
		return err
	}
	cmd := exec.CommandContext(ctx, p.RPKPath, "topic", "produce", dlqTopic, "--brokers", strings.Join(p.Brokers, ","))
	cmd.Stdin = bytes.NewReader(append(envelope, '\n'))
	if out, err := cmd.CombinedOutput(); err != nil {
		return fmt.Errorf("rpk produce dlq: %w: %s", err, strings.TrimSpace(string(out)))
	}
	return nil
}

func (p *RedpandaRPKPoller) Close() error { return nil }

// ConsumerMetrics is safe to read while the consumer is running.
type ConsumerMetrics struct {
	Consumed      int64 `json:"consumer_consumed_count"`
	Committed     int64 `json:"consumer_committed_count"`
	CommitErrors  int64 `json:"consumer_commit_error_count"`
	Lag           int64 `json:"consumer_lag"`
	DLQCount      int64 `json:"consumer_dlq_count"`
	PollErrors    int64 `json:"consumer_poll_error_count"`
	UpsertErrors  int64 `json:"consumer_upsert_error_count"`
	LastOffset    int64 `json:"consumer_last_offset"`
	LastPollUnix  int64 `json:"consumer_last_poll_unix"`
	LastErrorUnix int64 `json:"consumer_last_error_unix,omitempty"`
}

// EventConsumer runs the poll -> deserialize -> tank upsert -> offset commit loop.
type EventConsumer struct {
	Config  ConsumerConfig
	Poller  EventPoller
	Metrics ConsumerMetrics
	Upsert  TankUpsertFunc
}

func (c *EventConsumer) Topics() []string {
	if len(c.Config.Topics) > 0 {
		out := make([]string, 0, len(c.Config.Topics))
		for _, topic := range c.Config.Topics {
			if topic = strings.TrimSpace(topic); topic != "" {
				out = append(out, topic)
			}
		}
		return out
	}
	if topic := strings.TrimSpace(c.Config.Topic); topic != "" {
		return []string{topic}
	}
	return nil
}

func (c *EventConsumer) Run(ctx context.Context) error {
	if !c.Config.Enabled {
		return fmt.Errorf("consumer not enabled")
	}
	if c.Poller == nil {
		return fmt.Errorf("event poller is required")
	}
	if c.Upsert == nil {
		return fmt.Errorf("tank upsert hook is required")
	}
	topics := c.Topics()
	if len(topics) == 0 {
		return fmt.Errorf("at least one consumer topic is required")
	}
	maxPoll := c.Config.MaxPollRecords
	if maxPoll <= 0 {
		maxPoll = 100
	}
	defer func() {
		if err := c.Poller.Close(); err != nil {
			log.Printf("consumer poller close failed: %v", err)
		}
	}()
	for {
		if err := ctx.Err(); err != nil {
			return err
		}
		records, err := c.Poller.Poll(ctx, topics, maxPoll)
		atomic.StoreInt64(&c.Metrics.LastPollUnix, time.Now().Unix())
		if err != nil {
			atomic.AddInt64(&c.Metrics.PollErrors, 1)
			atomic.StoreInt64(&c.Metrics.LastErrorUnix, time.Now().Unix())
			log.Printf("consumer poll error type=%s group=%s: %v", c.Config.Type, c.Config.GroupID, err)
			time.Sleep(500 * time.Millisecond)
			continue
		}
		if len(records) == 0 {
			time.Sleep(250 * time.Millisecond)
			continue
		}
		for _, record := range records {
			if err := c.handleRecord(ctx, record); err != nil {
				log.Printf("consumer record error topic=%s partition=%d offset=%d: %v", record.Topic, record.Partition, record.Offset, err)
			}
		}
	}
}

func (c *EventConsumer) handleRecord(ctx context.Context, record ConsumerRecord) error {
	atomic.AddInt64(&c.Metrics.Consumed, 1)
	atomic.StoreInt64(&c.Metrics.LastOffset, record.Offset)
	payload, err := DeserializeRecord(record.Value, c.Config.Deserializer)
	if err != nil {
		return c.routeDLQ(ctx, record, err)
	}
	if record.Topic != "" {
		payload["_topic"] = record.Topic
	}
	payload["_partition"] = record.Partition
	payload["_offset"] = record.Offset
	if !record.Timestamp.IsZero() {
		payload["_event_time"] = record.Timestamp.UTC().Format(time.RFC3339Nano)
	}
	if err := c.Upsert(ctx, record.Topic, payload); err != nil {
		atomic.AddInt64(&c.Metrics.UpsertErrors, 1)
		return c.routeDLQ(ctx, record, err)
	}
	if err := c.Poller.Commit(ctx, record); err != nil {
		atomic.AddInt64(&c.Metrics.CommitErrors, 1)
		atomic.StoreInt64(&c.Metrics.LastErrorUnix, time.Now().Unix())
		return err
	}
	atomic.AddInt64(&c.Metrics.Committed, 1)
	atomic.StoreInt64(&c.Metrics.Lag, 0)
	return nil
}

func (c *EventConsumer) routeDLQ(ctx context.Context, record ConsumerRecord, cause error) error {
	atomic.AddInt64(&c.Metrics.DLQCount, 1)
	atomic.StoreInt64(&c.Metrics.LastErrorUnix, time.Now().Unix())
	if c.Config.DLQTopic != "" {
		if err := c.Poller.SendDLQ(ctx, c.Config.DLQTopic, record, cause); err != nil {
			return fmt.Errorf("dlq route failed after %v: %w", cause, err)
		}
		if err := c.Poller.Commit(ctx, record); err != nil {
			atomic.AddInt64(&c.Metrics.CommitErrors, 1)
			return fmt.Errorf("dlq offset commit failed after %v: %w", cause, err)
		}
		atomic.AddInt64(&c.Metrics.Committed, 1)
	}
	return cause
}

func DeserializeRecord(raw []byte, deserializer string) (map[string]any, error) {
	switch strings.TrimSpace(deserializer) {
	case "", "json":
		var m map[string]any
		if err := json.Unmarshal(raw, &m); err != nil {
			return nil, err
		}
		return m, nil
	case "avro-ref":
		return nil, fmt.Errorf("avro-ref requires schema-registry-url wiring")
	default:
		return nil, fmt.Errorf("unknown deserializer %q", deserializer)
	}
}
