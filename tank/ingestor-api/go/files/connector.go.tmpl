package {{ snake .TankName }}

import (
	"context"
	"encoding/json"
	"fmt"
	"io"
	"net/http"
	"time"
)

// Run executes one full pull cycle: paginate all pages, transform, embed, upsert.
// Called by the scheduler on every Schedule tick (see schedule.go).
func Run(ctx context.Context) error {
	client := NewClient()
	var page int
	for {
		records, nextCursor, err := fetchPage(ctx, client, page, "")
		if err != nil {
			return retryable(ctx, err, func() error { return Run(ctx) })
		}
		for _, r := range records {
			transformed := Transform(r)
			if err := upsert(ctx, transformed); err != nil {
				return err
			}
		}
		if nextCursor == "" {
			break
		}
		page++
	}
	return nil
}

// fetchPage retrieves one page of records from the upstream API.
// Supports cursor, offset, and link-header pagination strategies from TankConnectorConfig.pagination.
// response-path extraction is applied to unwrap the vendor envelope.
func fetchPage(ctx context.Context, client *http.Client, page int, cursor string) (records []json.RawMessage, nextCursor string, err error) {
	req, err := http.NewRequestWithContext(ctx, http.MethodGet, baseURL(page, cursor), nil)
	if err != nil {
		return nil, "", err
	}
	applyAuth(req)

	resp, err := client.Do(req)
	if err != nil {
		return nil, "", err
	}
	defer resp.Body.Close()

	if resp.StatusCode >= 400 {
		return nil, "", fmt.Errorf("upstream %s: %d", req.URL.Path, resp.StatusCode)
	}

	body, err := io.ReadAll(resp.Body)
	if err != nil {
		return nil, "", err
	}

	// response-path: extract records from vendor envelope (e.g. $.records[*], $.entry[*].resource).
	// Replace extractRecords with your JSONPath implementation or direct field access.
	records = extractRecords(body)

	// pagination: cursor strategy — read next-page token from response body.
	// For offset strategy: increment page counter in baseURL. For link-header: parse Link header.
	nextCursor = extractCursor(body, resp.Header)
	return records, nextCursor, nil
}

// upsert writes a transformed record into tank storage and embeds content-field.
func upsert(ctx context.Context, record []byte) error {
	// Wire to context-service tank upsert endpoint.
	// content-field value must be extracted and passed as the embedding input.
	_ = ctx
	_ = record
	return nil
}

// retryable applies exponential backoff from TankConnectorConfig.retry.
// Retries on 429, 500, 502, 503, 504 by default.
func retryable(ctx context.Context, err error, fn func() error) error {
	delay := 500 * time.Millisecond
	for attempt := 1; attempt <= 4; attempt++ {
		select {
		case <-ctx.Done():
			return ctx.Err()
		case <-time.After(delay):
		}
		if retryErr := fn(); retryErr == nil {
			return nil
		}
		delay *= 2
		if delay > 30*time.Second {
			delay = 30 * time.Second
		}
	}
	return err
}

// baseURL constructs the request URL for a given page/cursor.
// Adapt to your pagination strategy (cursor-param, page-param, $skip/$top, etc.).
func baseURL(page int, cursor string) string {
	_ = page
	_ = cursor
	return ""
}

// applyAuth injects authorization headers for the configured auth type
// (oauth2, apikey, bearer, basic). Reads from env vars declared in connector-config.auth.
func applyAuth(req *http.Request) {}

// extractRecords applies response-path JSONPath to unwrap vendor envelope.
func extractRecords(body []byte) []json.RawMessage { return nil }

// extractCursor reads next-page token from response body (cursor strategy)
// or Link: rel="next" header (link-header strategy).
func extractCursor(body []byte, header http.Header) string { return "" }
