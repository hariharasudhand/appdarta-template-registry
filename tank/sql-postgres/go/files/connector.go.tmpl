package {{ snake .TankName }}

import (
	"context"
	"database/sql"

	_ "github.com/lib/pq"
)

type Connector struct {
	db *sql.DB
}

func Open(dsn string) (*Connector, error) {
	db, err := sql.Open("postgres", dsn)
	if err != nil {
		return nil, err
	}
	return &Connector{db: db}, nil
}

func (c *Connector) Read(ctx context.Context, id string) (*sql.Row, error) {
	return c.db.QueryRowContext(ctx, "SELECT payload FROM {{ snake .TankName }} WHERE id = $1", id), nil
}
